# FILA2PRO — reverse proxy HTTPS via Caddy
# Certificat local auto-généré (CA interne Caddy)
#
# Adresse principale : https://stock.lan:9443
#   → nécessite une règle DNS dans Pi-hole : stock.lan → 192.168.1.200
# Adresse de secours : https://192.168.1.200.nip.io:9443 (fonctionne sans DNS)
#
# Le certificat est émis par la même CA locale, déjà installée sur vos appareils.

{
	auto_https disable_redirects
}

https://stock.lan:9443, https://fila2pro.lan:9443, https://192.168.1.200.nip.io:9443 {
	tls internal
	reverse_proxy fila2pro:8080
}
